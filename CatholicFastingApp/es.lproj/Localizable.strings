"guidance.pastoral_guidance" = "Guía pastoral";
"guidance.pastoral_line_1" = "Si está embarazada, en lactancia, es de edad avanzada, está enfermo, realiza trabajo intenso o tiene una condición crónica, busque orientación pastoral y médica antes de ayunar.";
"guidance.pastoral_line_2" = "Las dispensas y sustituciones pueden ser legítimas. Esta app es una ayuda, pero no sustituye a su párroco.";
"guidance.pastoral_line_3" = "En caso de duda, prefiera la caridad y la obediencia a la autoridad legítima de la Iglesia sobre el rigor autoimpuesto.";
"guidance.faq.title" = "Preguntas frecuentes (con fuentes)";
"guidance.faq.q1" = "P: ¿Cuáles son los días obligatorios de ayuno en la Iglesia latina? R: Miércoles de Ceniza y Viernes Santo.";
"guidance.faq.q2" = "P: ¿Qué significa abstinencia? R: Sin carne de animales terrestres; el pescado normalmente se permite.";
"guidance.faq.q3" = "P: ¿Los obispos locales cambian reglas? R: Sí, pueden existir normas locales y dispensas.";
"guidance.faq.sources" = "Fuentes: declaraciones pastorales de la USCCB y normas universales.";
"guidance.usccb.title" = "Ayuno y abstinencia USCCB (oficial)";
"guidance.usccb.summary" = "La USCCB indica que el Miércoles de Ceniza y el Viernes Santo son días obligatorios de ayuno y abstinencia para los católicos latinos.";
"guidance.usccb.fast_rule" = "El ayuno aplica desde los 18 hasta los 59 años.";
"guidance.usccb.abstinence_rule" = "La abstinencia de carne aplica desde los 14 años en adelante.";
"guidance.usccb.friday_rule" = "Los viernes de Cuaresma son días de abstinencia.";
"guidance.usccb.outside_lent_rule" = "Los viernes fuera de Cuaresma siguen siendo días penitenciales en EE. UU.; elija abstinencia u otro acto penitencial.";
"guidance.usccb.dispensation_note" = "Los párrocos y obispos locales pueden otorgar dispensas legítimas y normas locales.";
"guidance.usccb.link_label" = "Leer guía completa de ayuno y abstinencia de la USCCB";
"guidance.sources.local_decrees_note" = "Siempre confirme los decretos locales para su ubicación y año.";

