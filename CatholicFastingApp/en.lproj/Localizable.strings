"guidance.pastoral_guidance" = "Pastoral Guidance";
"guidance.pastoral_line_1" = "If you are pregnant, nursing, elderly, ill, under intense labor, or managing chronic conditions, seek pastoral and medical guidance before fasting.";
"guidance.pastoral_line_2" = "Dispensations and substitutions can be legitimate. The app is an aid, not a substitute for your pastor.";
"guidance.pastoral_line_3" = "When in doubt, choose charity and obedience to lawful Church authority over self-imposed rigor.";
"guidance.faq.title" = "FAQ (With Sources)";
"guidance.faq.q1" = "Q: What are mandatory fast days in the Latin Church? A: Ash Wednesday and Good Friday.";
"guidance.faq.q2" = "Q: What does abstinence mean? A: No meat from land animals; fish is generally permitted.";
"guidance.faq.q3" = "Q: Do local bishops change rules? A: Yes, local norms and dispensations may apply.";
"guidance.faq.sources" = "Sources: USCCB pastoral statements and universal norms.";
"guidance.usccb.title" = "USCCB Fast & Abstinence (Official)";
"guidance.usccb.summary" = "USCCB states that Ash Wednesday and Good Friday are obligatory days of fasting and abstinence for Latin Catholics.";
"guidance.usccb.fast_rule" = "Fasting applies from age 18 until age 59.";
"guidance.usccb.abstinence_rule" = "Abstinence from meat applies from age 14 onward.";
"guidance.usccb.friday_rule" = "Fridays in Lent are days of abstinence.";
"guidance.usccb.dispensation_note" = "Pastors and local bishops may give legitimate dispensations and local norms.";
"guidance.usccb.link_label" = "Read Full USCCB Fast & Abstinence Guidelines";
"guidance.sources.local_decrees_note" = "Always confirm local decrees for your location and year.";

